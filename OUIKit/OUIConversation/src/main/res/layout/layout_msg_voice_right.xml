<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="8dp"
    android:paddingEnd="16dp">

    <io.openim.android.ouiconversation.widget.SendStateView
        android:id="@+id/sendState2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/voiceContainer2"
        android:layout_marginEnd="8dp"
        android:layout_toStartOf="@id/voiceContainer2" />

    <LinearLayout
        android:id="@+id/voiceContainer2"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/nickName2"
        android:layout_marginEnd="8dp"
        android:layout_toStartOf="@id/avatar2"
        android:background="@drawable/bg_chat_bubble_right"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/voiceDuration2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text='0"'
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/voiceIcon2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@mipmap/ic_voice_s1" />
    </LinearLayout>

    <TextView
        android:id="@+id/nickName2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignEnd="@id/voiceContainer2"
        android:layout_alignParentTop="true"
        android:textColor="#999999"
        android:textSize="12sp"
        android:visibility="gone" />

    <io.openim.android.ouicore.widget.AvatarImage
        android:id="@+id/avatar2"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true" />
</RelativeLayout>